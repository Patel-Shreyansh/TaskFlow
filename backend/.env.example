# Copy this file to .env and fill in real values.
# .env is git-ignored, so your secrets never get committed.

PORT=5001
NODE_ENV=development

# Use a long, random string in real deployments, e.g. `openssl rand -hex 32`
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

DB_PATH=data/taskflow.db

# Set this to your deployed frontend origin in production, e.g. https://taskflow.app
CORS_ORIGIN=*
